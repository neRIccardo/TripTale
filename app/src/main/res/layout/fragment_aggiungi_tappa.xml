<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/sfondo_principale"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/titolo_nuova_tappa"
            android:textColor="@color/bianco"
            android:textSize="28sp"
            android:textStyle="bold"
            android:layout_marginBottom="24dp"/>

        <EditText
            android:id="@+id/editTitoloTappa"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/hint_titolo_tappa"
            android:importantForAutofill="no"
            android:textColorHint="@color/grigio_scuro"
            android:minHeight="48dp"
            android:textColor="@color/bianco"
            android:backgroundTint="@color/arancione_triptale"
            android:inputType="textCapSentences"
            android:layout_marginBottom="16dp"/>

        <EditText
            android:id="@+id/editNoteTappa"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/hint_note_tappa"
            android:importantForAutofill="no"
            android:textColorHint="@color/grigio_scuro"
            android:textColor="@color/bianco"
            android:backgroundTint="@color/arancione_triptale"
            android:inputType="textMultiLine"
            android:minLines="4"
            android:gravity="top"
            android:layout_marginBottom="24dp"/>

        <ImageView
            android:id="@+id/imageAnteprimaFoto"
            android:layout_width="match_parent"
            android:layout_height="200dp"
            android:background="@color/sfondo_secondario"
            android:scaleType="fitCenter"
            android:layout_marginBottom="16dp"
            android:contentDescription="@string/desc_anteprima_foto"/>

        <Button
            android:id="@+id/btnScattaFoto"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/btn_scatta_foto"
            android:backgroundTint="@color/sfondo_pulsante_secondario"
            android:textColor="@color/bianco"
            android:layout_marginBottom="32dp"/>

        <Button
            android:id="@+id/btnSalvaTappa"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:text="@string/btn_salva_tappa"
            android:backgroundTint="@color/arancione_triptale"
            android:textColor="@color/bianco"
            android:textStyle="bold"
            android:textSize="18sp"/>

    </LinearLayout>
</ScrollView>