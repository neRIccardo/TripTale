<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/sfondo_principale"
    android:fillViewport="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="24dp">

        <TextView
            android:id="@+id/textTitoloPagina"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/titolo_nuovo_viaggio"
            android:textColor="@color/bianco"
            android:textSize="28sp"
            android:textStyle="bold"
            android:layout_marginTop="32dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent" />

        <EditText
            android:id="@+id/editTitoloViaggio"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="40dp"
            android:backgroundTint="@color/arancione_triptale"
            android:hint="@string/hint_dove_andiamo"
            android:importantForAutofill="no"
            android:inputType="textCapSentences"
            android:minHeight="48dp"
            android:textColor="@color/bianco"
            android:textColorHint="@color/grigio_scuro"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/textTitoloPagina" />

        <EditText
            android:id="@+id/editCittaViaggio"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:backgroundTint="@color/arancione_triptale"
            android:hint="@string/hint_citta_destinazione"
            android:importantForAutofill="no"
            android:inputType="textCapWords"
            android:minHeight="48dp"
            android:textColor="@color/bianco"
            android:textColorHint="@color/grigio_scuro"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/editTitoloViaggio" />

        <TextView
            android:id="@+id/textAiutoCitta"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="@string/aiuto_citta_meteo"
            android:textColor="@color/arancione_triptale"
            android:textSize="12sp"
            app:layout_constraintTop_toBottomOf="@id/editCittaViaggio"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <EditText
            android:id="@+id/editDataInizio"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:backgroundTint="@color/arancione_triptale"
            android:hint="@string/hint_data_inizio"
            android:importantForAutofill="no"
            android:inputType="date"
            android:minHeight="48dp"
            android:textColor="@color/bianco"
            android:textColorHint="@color/grigio_scuro"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/textAiutoCitta" />

        <EditText
            android:id="@+id/editDataFine"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:backgroundTint="@color/arancione_triptale"
            android:hint="@string/hint_data_fine"
            android:importantForAutofill="no"
            android:inputType="date"
            android:minHeight="48dp"
            android:textColor="@color/bianco"
            android:textColorHint="@color/grigio_scuro"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/editDataInizio" />

        <Button
            android:id="@+id/btnSalvaViaggio"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="48dp"
            android:text="@string/btn_salva_viaggio"
            android:textColor="@color/bianco"
            android:backgroundTint="@color/arancione_triptale"
            app:layout_constraintTop_toBottomOf="@id/editDataFine"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</ScrollView>