<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/sfondo_principale"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/titolo_modifica_viaggio"
            android:textColor="@color/bianco"
            android:textSize="28sp"
            android:textStyle="bold"
            android:layout_marginBottom="24dp"/>

        <EditText
            android:id="@+id/editTitoloModifica"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/hint_titolo_viaggio"
            android:importantForAutofill="no"
            android:inputType="textCapWords"
            android:textColor="@color/bianco"
            android:textColorHint="@color/grigio_scuro"
            android:backgroundTint="@color/arancione_triptale"
            android:layout_marginBottom="8dp"/>

        <EditText
            android:id="@+id/editCittaModifica"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/hint_citta_destinazione"
            android:importantForAutofill="no"
            android:textColor="@color/bianco"
            android:textColorHint="@color/grigio_scuro"
            android:backgroundTint="@color/arancione_triptale"
            android:inputType="textCapWords"
            android:layout_marginBottom="4dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/aiuto_citta_meteo"
            android:textColor="@color/arancione_triptale"
            android:textSize="12sp"
            android:layout_marginBottom="16dp" />

        <EditText
            android:id="@+id/editDataInizioModifica"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/hint_data_inizio"
            android:importantForAutofill="no"
            android:inputType="date"
            android:textColor="@color/bianco"
            android:textColorHint="@color/grigio_scuro"
            android:backgroundTint="@color/arancione_triptale"
            android:layout_marginBottom="16dp"/>

        <EditText
            android:id="@+id/editDataFineModifica"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/hint_data_fine"
            android:inputType="date"
            android:importantForAutofill="no"
            android:textColor="@color/bianco"
            android:textColorHint="@color/grigio_scuro"
            android:backgroundTint="@color/arancione_triptale"
            android:layout_marginBottom="24dp"/>

        <ImageView
            android:id="@+id/imageCopertinaViaggio"
            android:layout_width="match_parent"
            android:layout_height="200dp"
            android:background="@color/sfondo_secondario"
            android:scaleType="centerCrop"
            android:layout_marginBottom="16dp"
            android:contentDescription="@string/desc_copertina_viaggio"/>

        <Button
            android:id="@+id/btnSelezionaFotoCopertina"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/btn_seleziona_copertina"
            android:backgroundTint="@color/sfondo_pulsante_secondario"
            android:textColor="@color/bianco"
            android:layout_marginBottom="32dp"/>

        <View
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <Button
            android:id="@+id/btnSalvaModifiche"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:text="@string/btn_salva_modifiche"
            android:backgroundTint="@color/arancione_triptale"
            android:textColor="@color/bianco"
            android:textStyle="bold"/>
    </LinearLayout>
</ScrollView>