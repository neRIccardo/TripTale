<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#121212"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Modifica viaggio"
            android:textColor="#FFFFFF"
            android:textSize="28sp"
            android:textStyle="bold"
            android:layout_marginBottom="24dp"/>

        <EditText
            android:id="@+id/editTitoloModifica"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Titolo viaggio"
            android:textColor="#FFFFFF"
            android:textColorHint="#888888"
            android:backgroundTint="#E73B18"
            android:layout_marginBottom="8dp"/>

        <EditText
            android:id="@+id/editCittaModifica"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Città di destinazione"
            android:textColor="#FFFFFF"
            android:textColorHint="#888888"
            android:backgroundTint="#E73B18"
            android:inputType="textCapWords"
            android:layout_marginBottom="4dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Riempi il campo per abilitare il servizio di previsioni meteo"
            android:textColor="#E73B18"
            android:textSize="12sp"
            android:layout_marginBottom="16dp" />

        <EditText
            android:id="@+id/editDataInizioModifica"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Data Inizio"
            android:textColor="#FFFFFF"
            android:textColorHint="#888888"
            android:backgroundTint="#E73B18"
            android:layout_marginBottom="16dp"/>

        <EditText
            android:id="@+id/editDataFineModifica"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Data Fine"
            android:textColor="#FFFFFF"
            android:textColorHint="#888888"
            android:backgroundTint="#E73B18"
            android:layout_marginBottom="24dp"/>

        <ImageView
            android:id="@+id/imageCopertinaViaggio"
            android:layout_width="match_parent"
            android:layout_height="200dp"
            android:background="#1E1E1E"
            android:scaleType="centerCrop"
            android:layout_marginBottom="16dp"/>

        <Button
            android:id="@+id/btnSelezionaFotoCopertina"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Seleziona copertina del viaggio"
            android:backgroundTint="#333333"
            android:textColor="#FFFFFF"
            android:layout_marginBottom="32dp"/>

        <View
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <Button
            android:id="@+id/btnSalvaModifiche"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:text="SALVA MODIFICHE"
            android:backgroundTint="#E73B18"
            android:textColor="#FFFFFF"
            android:textStyle="bold"/>
    </LinearLayout>
</ScrollView>