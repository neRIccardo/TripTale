<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:padding="16dp"
    android:layout_marginBottom="12dp"
    android:background="@color/sfondo_card"
    android:gravity="center_vertical">

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:layout_marginEnd="16dp">

        <TextView
            android:id="@+id/textTitoloTappa"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/bianco"
            android:textSize="20sp"
            android:textStyle="bold"
            tools:text="Colosseo" />

        <TextView
            android:id="@+id/textNoteTappa"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:textColor="@color/grigio_medio_chiaro"
            android:textSize="16sp"
            android:maxLines="3"
            android:ellipsize="end"
            tools:text="Oggi abbiamo visitato il Colosseo, fantastico!" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="12dp">

            <ImageButton
                android:id="@+id/btnModificaTappa"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@android:drawable/ic_menu_edit"
                app:tint="@color/verde_successo"
                android:contentDescription="@string/desc_btn_modifica_tappa" />

            <ImageButton
                android:id="@+id/btnEliminaTappa"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@android:drawable/ic_menu_delete"
                android:layout_marginStart="16dp"
                app:tint="@color/arancione_triptale"
                android:contentDescription="@string/desc_btn_elimina_tappa" />
        </LinearLayout>
    </LinearLayout>

    <ImageView
        android:id="@+id/imageMiniaturaTappa"
        android:layout_width="90dp"
        android:layout_height="90dp"
        android:scaleType="centerCrop"
        android:background="@color/arancione_triptale"
        android:padding="2dp"
        android:cropToPadding="true"
        android:src="@android:drawable/ic_menu_camera"
        android:contentDescription="@string/desc_miniatura_tappa" />

</LinearLayout>